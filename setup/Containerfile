# syntax=docker/dockerfile:1
FROM docker.io/library/nginx:1.27-alpine

# Install node for a tiny SSE server
RUN apk add --no-cache nodejs-current npm

# Clear default html and copy our static site
RUN rm -rf /usr/share/nginx/html/*
COPY index.html /usr/share/nginx/html/index.html
COPY assets/ /usr/share/nginx/html/assets/

# Configure nginx via template processed at container start (envsubst)
RUN mkdir -p /etc/nginx/templates
COPY setup/default.conf.template /etc/nginx/templates/default.conf.template
RUN rm -f /etc/nginx/conf.d/default.conf
ENV NGINX_ENVSUBST_VARS="$AAP_BASE_URL $AAP_BEARER_TOKEN $API_CLIENT_BEARER_TOKEN"

# Copy UI SSE server
COPY setup/ui-server/ /opt/ui-server/

# Start both nginx and SSE server
CMD sh -lc 'node /opt/ui-server/server.js & exec /docker-entrypoint.sh nginx -g "daemon off;"'

EXPOSE 80


