[Unit]
Description=SCUI nginx container
After=network-online.target
Wants=network-online.target

[Container]
Image={{ (image_ref | length > 0) | ternary(image_ref, image_name) }}
Name={{ container_name }}
PublishPort={{ host_http_port }}:80
Restart=always
Env=AAP_BASE_URL={{ aap_base_url | default('') }}
Env=AAP_BEARER_TOKEN={{ aap_bearer_token | default('') }}
Env=API_CLIENT_BEARER_TOKEN={{ api_client_bearer_token | default('') }}

[Install]
WantedBy=default.target


